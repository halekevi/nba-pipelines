# Copy to a local file outside git (e.g. `.env` or `private/.env`) — never commit real values.
#
# DATABASE_URL=postgresql://user:pass@host:5432/proporacle
# PROPORACLE_DB_PATH=C:/path/to/proporacle_income.db
# Income dashboard: local auto-seeds demo bets when empty; set to 0 to disable.
# PROPORACLE_INCOME_SEED_DEMO=0
# On Railway, set to 1 once if you want demo charts without real ingest.
# PROPORACLE_INCOME_SEED_DEMO=1
# PP_COOKIE=
# ODDS_API_KEY=
# GOOGLE_API_KEY=
