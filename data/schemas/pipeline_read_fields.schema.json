{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://proporacle.local/schemas/pipeline_read_fields.schema.json",
  "title": "PipelineReadFields",
  "type": "object",
  "required": [
    "sport",
    "player",
    "prop_type",
    "direction",
    "pick_type",
    "line",
    "rank_score",
    "hit_prob_over",
    "hit_prob_under",
    "hit_prob_selected",
    "edge",
    "data_completeness_score"
  ],
  "properties": {
    "sport": { "type": "string" },
    "player": { "type": "string" },
    "team": { "type": "string" },
    "opp": { "type": "string" },
    "game_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "game_time": { "type": "string" },
    "prop_type": { "type": "string" },
    "direction": { "enum": ["OVER", "UNDER"] },
    "pick_type": { "enum": ["Standard", "Goblin", "Demon", "standard", "goblin", "demon"] },
    "line": { "type": "number" },
    "standard_line": { "type": ["number", "null"] },
    "projection": { "type": ["number", "null"] },
    "edge": { "type": ["number", "null"] },
    "abs_edge": { "type": ["number", "null"] },
    "edge_signed": { "type": ["number", "null"] },
    "edge_pct_vs_line": { "type": ["number", "null"] },
    "line_delta_vs_standard": { "type": ["number", "null"] },
    "rank_score": { "type": ["number", "null"] },
    "tier": { "type": "string" },
    "ml_prob": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "hit_rate": { "type": ["number", "null"] },
    "over_hit_rate": { "type": ["number", "null"] },
    "under_hit_rate": { "type": ["number", "null"] },
    "l5_over": { "type": ["number", "null"] },
    "l5_under": { "type": ["number", "null"] },
    "l10_over": { "type": ["number", "null"] },
    "l10_under": { "type": ["number", "null"] },
    "hit_prob_over": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "hit_prob_under": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "hit_prob_selected": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "leg_prob_used": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "leg_prob_source": { "type": "string" },
    "def_tier": { "type": "string" },
    "opponent_def_rank": { "type": ["number", "null"] },
    "def_matchup_signal": { "type": ["number", "null"] },
    "l5_side_hit_rate": { "type": ["number", "null"] },
    "l10_side_hit_rate": { "type": ["number", "null"] },
    "consistency_score": { "type": ["number", "null"] },
    "prop_quality_score": { "type": ["number", "null"] },
    "data_completeness_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "read_fields_missing": { "type": "array", "items": { "type": "string" } },
    "pick_type_eligible": { "type": "boolean" },
    "rank_edge_component": { "type": ["number", "null"] },
    "rank_prob_component": { "type": ["number", "null"] },
    "rank_consistency_component": { "type": ["number", "null"] },
    "rank_matchup_component": { "type": ["number", "null"] },
    "rank_tier_component": { "type": ["number", "null"] }
  },
  "additionalProperties": true
}
