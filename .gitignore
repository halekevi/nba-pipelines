data/cache/
data/cache/*.db
data/cache/*.db-wal
data/cache/*.db-shm
Tennis/cache/
MLB/mlb_stats_cache.csv

# Fetch error log — local only
logs/fetch_errors.log

# Synthetic preview CSVs — local only
outputs/synthetic/preview_*.csv

# Archives
*.zip
*.7z
*.rar

# Excel temp files
~$*.xlsx
~$*.xls

# Generated outputs
outputs/
ResultFiles/
**/outputs/
**/ResultFiles/
grades/
models/

# Generated html/json artifacts if you don't want tracked
