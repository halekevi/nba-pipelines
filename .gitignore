# Capacitor (mobile/) — install locally; do not commit npm tree
mobile/node_modules/
mobile/android/**/build/
mobile/android/.gradle/
mobile/android/local.properties
mobile/android/captures/
mobile/android/*.iml
mobile/android/.idea/

# Build artifacts
build/
dist/
*.egg-info/

# Binary/media scratch
*.png
*.jpg
*.jpeg
*.webp
*.gif

# Launcher assets for Capacitor Android (override ignores above)
!mobile/android/app/src/main/res/mipmap-*/*.png
!mobile/android/app/src/main/res/mipmap-*/*.webp

# Browser/session runtime artifacts (never commit)
browser_session/
browser_session_harvest2/
chrome_cdp_profile/

# One-off exported design snapshots
ui_runner/static/Logo Design Request.html
ui_runner/static/Logo Design Request2.html
ui_runner/static/Logo Design Request_files/
ui_runner/static/Logo Design Request2_files/

# Docs/temp/patch leftovers
*.bak_*
ui_runner/data/backups/
!ui_runner/data/backups/
!ui_runner/data/backups/.gitkeep

git_push_log.txt
patch_replacement.txt

# weird temp file
$null

