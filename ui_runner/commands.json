            "10.0",
            "--output",
            "step1_pp_props_today.csv"
          ]
        },
        {
          "id": "nba_step2",
          "label": "Step 2 — Attach Pick Types",
          "cmd": [
            "py",
            "-3.14",
            ".\\scripts\\step2_attach_picktypes.py",
            "--input",
            "step1_pp_props_today.csv",
            "--output",
            "step2_with_picktypes.csv"
          ]
        },
        {
          "id": "nba_step3",
          "label": "Step 3 — Attach Defense",
          "cmd": [
            "py",
            "-3.14",
            ".\\scripts\\step3_attach_defense.py",
            "--input",
            "step2_with_picktypes.csv",
