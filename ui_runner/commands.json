            "--output",
            "best_tickets.xlsx",
            "--min_hit_rate",
            "0.8",
            "--legs",
            "2,3,4"
          ]
        },
        {
          "id": "nba_full",
          "label": "NBA Full Pipeline (Steps 1-9)",
          "cmd_chain": [
            "nba_step1",
            "nba_step2",
            "nba_step3",
