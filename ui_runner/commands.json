            "--out",
            "step4_with_stats.csv",
            "--season",
            "2025-26",
            "--date",
            "{TODAY}",
            "--days",
            "35",
            "--cache",
            "nba_espn_boxscore_cache.csv",
            "--idmap",
            "nba_to_espn_id_map.csv",
            "--n",
            "10",
            "--sleep",
            "0.8",
            "--retries",
            "4",
            "--connect-timeout",
            "8",
            "--timeout",
            "30",
            "--debug-misses",
            "no_espn_player_debug.csv",
            "--workers",
            "4"
          ]
        },
        {
          "id": "nba_step5",
          "label": "Step 5 — Line Hit Rates",
          "cmd": [
            "py",
            "-3.14",
            ".\\scripts\\step5_add_line_hit_rates.py",
            "--input",
            "step4_with_stats.csv",
            "--output",
            "step5_with_hit_rates.csv"
          ]
        },
        {
          "id": "nba_step6",
          "label": "Step 6 — Team Role Context",
          "cmd": [
            "py",
            "-3.14",
            ".\\scripts\\step6_team_role_context.py",
            "--input",
            "step5_with_hit_rates.csv",
            "--output",
            "step6_with_team_role_context.csv"
          ]
        },
        {
          "id": "nba_step7",
          "label": "Step 7 — Rank Props",
          "cmd": [
            "py",
            "-3.14",
            ".\\scripts\\step7_rank_props.py",
            "--input",
            "step6_with_team_role_context.csv",
            "--output",
            "step7_ranked_props.xlsx"
          ]
        },
        {
          "id": "nba_step8",
          "label": "Step 8 — Direction Context",
          "cmd": [
            "py",
            "-3.14",
            ".\\scripts\\step8_add_direction_context.py",
            "--input",
            "step7_ranked_props.xlsx",
            "--sheet",
            "ALL",
            "--output",
            "step8_all_direction_clean.xlsx"
