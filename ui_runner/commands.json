      "commands": [
        {
          "id": "nba_step1",
          "label": "Step 1 — Fetch PrizePicks",
          "cmd": [
            "py",
            "-3.14",
            ".\\scripts\\step1_fetch_prizepicks_api.py",
            "--league_id",
            "7",
            "--game_mode",
            "pickem",
            "--per_page",
            "250",
            "--max_pages",
            "5",
            "--sleep",
            "2.0",
            "--cooldown_seconds",
            "90",
            "--max_cooldowns",
            "3",
